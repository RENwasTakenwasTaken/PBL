#:import dp kivy.metrics.dp
#:import Waveform waveform.Waveform

<MainLayout>:
    orientation: "vertical"
    padding: [40, 20, 20, 20]
    spacing: dp(12)

    canvas.before:
        Color:
            rgba: 0.08, 0.09, 0.12, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        size_hint_y: None
        height: dp(48)
        spacing: dp(12)

        Image:
            source: "media/heart-rate-icon.png"
            size_hint: None, None
            size: dp(32), dp(32)
            color: root.heart_icon_color

        Label:
            text: root.title_text
            halign: "left"
            valign: "middle"
            text_size: self.size
            color: 1, 1, 1, 1
            bold: True
            font_size: "22sp"

        Label:
            text: "SpO2: " + root.spo2
            text_size: self.size

        Label:
            text: "HR: " + root.heartrate
            text_size: self.size

    Label:
        size_hint_y: None
        height: dp(28)
        text: root.status_text
        halign: "left"
        valign: "middle"
        text_size: self.size
        color: 0.8, 0.84, 0.9, 1

    Label:
        size_hint_y: None
        height: dp(22)
        text: "Red Channel"
        halign: "left"
        valign: "middle"
        text_size: self.size
        color: 0.1, 0.9, 0.4, 1

    Waveform:
        id: top_waveform
        size_hint_y: 1
        ymin: 0
        ymax: 1024
        fps: 60
        time_window_sec: 20
        major_x_ticks: 5
        major_y_ticks: 5
        auto_scale: True
        max_ymax: 35000
        min_ymin: -35000
        graph_color: 0.1, 0.9, 0.4, 1

    Label:
        size_hint_y: None
        height: dp(22)
        text: "IR Channel"
        halign: "left"
        valign: "middle"
        text_size: self.size
        color: 0.95, 0.35, 0.2, 1

    Waveform:
        id: bottom_waveform
        size_hint_y: 1
        ymin: 0
        ymax: 1024
        fps: 60
        time_window_sec: 20
        major_x_ticks: 5
        major_y_ticks: 5
        auto_scale: True
        max_ymax: 35000
        min_ymin: -35000
        graph_color: 0.95, 0.35, 0.2, 1

    Label:
        size_hint_y: None
        height: dp(22)
        text: "Pleth Graph"
        halign: "left"
        valign: "middle"
        text_size: self.size
        color: 0.2, 0.5, 1, 1

    Waveform:
        id: pleth_waveform
        size_hint_y: 1
        ymin: 0
        ymax: 100
        fps: 60
        time_window_sec: 20
        major_x_ticks: 5
        major_y_ticks: 5
        auto_scale: True
        max_ymax: 150
        min_ymin: 0
        graph_color: 0.2, 0.5, 1, 1

MainLayout:
